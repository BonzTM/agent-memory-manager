# ACM runtime configuration
# Copy this file to .env to override local defaults.
ACM_PROJECT_ID=myproject
ACM_PROJECT_ROOT=/path/to/repo
ACM_SQLITE_PATH=.acm/context.db
ACM_PG_DSN=postgres://user:pass@localhost:5432/agents_context?sslmode=disable
ACM_UNBOUNDED=false
ACM_LOG_LEVEL=info
ACM_LOG_SINK=stderr

# AMM runtime configuration (optional)
# See docs/configuration.md for full reference.

# --- Storage ---
AMM_DB_PATH=~/.amm/amm.db
# AMM_STORAGE_BACKEND=sqlite       # sqlite (default) or postgres
# AMM_POSTGRES_DSN=postgres://user:pass@localhost:5432/amm?sslmode=disable

# --- HTTP Server (amm-http only) ---
# AMM_HTTP_ADDR=:8080
# AMM_HTTP_CORS_ORIGINS=*

# --- Retrieval ---
# AMM_DEFAULT_LIMIT=10
# AMM_AMBIENT_LIMIT=5
# AMM_ENABLE_SEMANTIC=false      # recall-time semantic scoring toggle
# AMM_ENABLE_EXPLAIN=true

# --- Privacy ---
# AMM_DEFAULT_PRIVACY=private

# --- Maintenance jobs ---
# AMM_AUTO_REFLECT=true
# AMM_AUTO_COMPRESS=true
# AMM_AUTO_CONSOLIDATE=true
# AMM_AUTO_DETECT_CONTRADICTIONS=true

# --- Summarizer / LLM extraction ---
# Enables LLM-backed memory extraction, NER entity extraction, and relationship inference.
# Without these, AMM uses heuristic extraction.
AMM_SUMMARIZER_ENDPOINT=https://api.openai.com/v1
AMM_SUMMARIZER_API_KEY=sk-your-key-here
AMM_SUMMARIZER_MODEL=gpt-4o-mini
# AMM_SUMMARIZER_BATCH_SIZE=20
# AMM_REFLECT_BATCH_SIZE=100
# AMM_REFLECT_LLM_BATCH_SIZE=20
# AMM_COMPRESS_CHUNK_SIZE=10
# AMM_COMPRESS_MAX_EVENTS=200
# AMM_COMPRESS_BATCH_SIZE=15
# AMM_TOPIC_BATCH_SIZE=15
# AMM_LIFECYCLE_REVIEW_BATCH_SIZE=50
# AMM_CROSS_PROJECT_SIMILARITY_THRESHOLD=0.7

# --- Review model (optional, separate LLM for lifecycle review/consolidation) ---
# Defaults to the summarizer model if unset.
# AMM_REVIEW_ENDPOINT=https://api.openai.com/v1
# AMM_REVIEW_API_KEY=sk-your-review-key-here
# AMM_REVIEW_MODEL=gpt-4o

# --- Embeddings (semantic recall) ---
# Set AMM_EMBEDDINGS_ENABLED=true to generate/store embeddings.
# Use AMM_ENABLE_SEMANTIC=true to apply semantic scoring during recall.
# Supports any OpenAI-compatible embeddings API (OpenAI, Ollama, OpenRouter, etc.).
AMM_EMBEDDINGS_ENABLED=false
# AMM_EMBEDDINGS_PROVIDER=openai
AMM_EMBEDDINGS_ENDPOINT=http://localhost:11434/v1
AMM_EMBEDDINGS_API_KEY=ollama
AMM_EMBEDDINGS_MODEL=nomic-embed-text
# AMM_EMBEDDING_BATCH_SIZE=64
