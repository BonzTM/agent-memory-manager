# ACM runtime configuration
# Copy this file to .env to override local defaults.
ACM_PROJECT_ID=myproject
ACM_PROJECT_ROOT=/path/to/repo
ACM_SQLITE_PATH=.acm/context.db
ACM_PG_DSN=postgres://user:pass@localhost:5432/agents_context?sslmode=disable
ACM_UNBOUNDED=false
ACM_LOG_LEVEL=info
ACM_LOG_SINK=stderr

# AMM runtime configuration (optional)
AMM_DB_PATH=~/.amm/amm.db
AMM_SUMMARIZER_ENDPOINT=https://api.openai.com/v1
AMM_SUMMARIZER_API_KEY=sk-your-key-here
AMM_SUMMARIZER_MODEL=gpt-4o-mini
AMM_SUMMARIZER_BATCH_SIZE=20
AMM_EMBEDDINGS_ENABLED=false
AMM_EMBEDDINGS_PROVIDER=local-noop
AMM_EMBEDDINGS_ENDPOINT=http://localhost:11434/v1
AMM_EMBEDDINGS_API_KEY=ollama
AMM_EMBEDDINGS_MODEL=nomic-embed-text
