{
  "plugins": {
    "entries": {
      "@bonztm/amm": {
        "enabled": true,
        "config": {
          "projectId": "my-project",
          "recallLimit": 5
        }
      },
      "acpx": {
        "enabled": true,
        "config": {
          "mcpServers": {
            "amm": {
              "command": "/usr/local/bin/amm-mcp",
              "args": [],
              "env": {
                "AMM_DB_PATH": "/home/you/.amm/amm.db"
              }
            }
          }
        }
      }
    }
  }
}
