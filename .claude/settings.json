{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/acm-session-context.sh",
            "type": "command"
          }
        ],
        "matcher": "startup|resume|clear|compact"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/acm-session-context.sh",
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/acm-receipt-guard.sh",
            "type": "command"
          }
        ],
        "matcher": "Edit|MultiEdit|Write|NotebookEdit"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/acm-edit-state.sh",
            "type": "command"
          }
        ],
        "matcher": "Edit|MultiEdit|Write|NotebookEdit"
      },
      {
        "hooks": [
          {
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/acm-receipt-mark.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ]
  }
}